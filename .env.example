# TMDB — chiave API (https://www.themoviedb.org/settings/api)
# Senza prefisso VITE_: usata dal proxy server (Vercel serverless / Vite dev proxy).
# Su Vercel: aggiungila in Project Settings > Environment Variables come TMDB_API_KEY.
TMDB_API_KEY=

# Supabase - Project URL e anon key (dashboard Supabase > Project Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
